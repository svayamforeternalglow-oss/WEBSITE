# Svayam-Natural-Backend environment example
# Copy this to .env in the Svayam-Natural-Backend folder (do NOT commit real secrets).

# Resend (transactional email)
RESEND_API_KEY=sk_resend_xxx_replaceme
RESEND_FROM_EMAIL=orders@yourdomain.com

# SMTP fallback (Brevo example)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Local test email target used by scripts/send-test-email.js
TEST_TARGET_EMAIL=test@example.com

# Database (example)
MONGO_URI=mongodb://localhost:27017/svayam
